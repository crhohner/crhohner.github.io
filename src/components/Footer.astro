<style>
  footer {
    padding: 2em 1em 6em 1em;
    color: var(--copy-dark);
    text-align: center;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1em;
    margin-top: 1em;
  }
  .social-links a {
    text-decoration: none;
    color: var(--copy);
  }
  .social-links a:hover {
    color: var(--copy-dark);
  }
</style>
